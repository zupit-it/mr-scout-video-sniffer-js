{
  "name": "@zupit-it/mr-scout-video-sniffer-js",
  "version": "0.2.1",
  "description": "Predizione client-side (browser/WASM) di video originale da fotocamera vs. ricodificato, analizzando i metadati. Framework-agnostica: usabile da Angular, React o vanilla.",
  "keywords": [
    "video",
    "metadata",
    "ffprobe",
    "mediainfo",
    "transcode",
    "recompression",
    "forensics",
    "browser",
    "wasm",
    "angular"
  ],
  "license": "MIT",
  "author": "Simonpaolo Lopez",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/zupit-it/mr-scout-video-sniffer-js.git"
  },
  "homepage": "https://github.com/zupit-it/mr-scout-video-sniffer-js#readme",
  "bugs": {
    "url": "https://github.com/zupit-it/mr-scout-video-sniffer-js/issues"
  },
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepublishOnly": "npm run typecheck && npm run test && npm run build"
  },
  "dependencies": {
    "mediainfo.js": "0.3.7"
  },
  "devDependencies": {
    "tsup": "^8.0.0",
    "typescript": "^5.4.0",
    "vitest": "^1.5.0"
  },
  "engines": {
    "node": ">=18"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://npm.pkg.github.com"
  }
}
